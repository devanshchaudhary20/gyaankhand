# Instagram API (Instagram Login / Business Login flow)
# These come from your "Instagram" product page in the Meta Developer dashboard,
# NOT the top-level Facebook app credentials.
IG_LONG_LIVED_TOKEN=
IG_USER_ID=
IG_APP_ID=
IG_APP_SECRET=

# GitHub repo info (used to construct the public image URL the API fetches)
# e.g. rayyanop61/gyaankhand
GITHUB_REPO=
GITHUB_BRANCH=main

# Account display info (used in caption)
IG_HANDLE=@your_handle_here
