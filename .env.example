# Instagram API (Instagram Login / Business Login flow)
# These come from your "Instagram" product page in the Meta Developer dashboard,
# NOT the top-level Facebook app credentials.
IG_LONG_LIVED_TOKEN=
IG_USER_ID=
IG_APP_ID=
IG_APP_SECRET=

# GitHub repo info (used to construct the public image URL the API fetches)
# e.g. owner/gyaankhand
GITHUB_REPO=
GITHUB_BRANCH=main

# Account display info (used in caption)
IG_HANDLE=@your_ig_handle

# YouTube API (OAuth 2.0 — for YouTube Shorts upload)
# 1. Go to console.cloud.google.com → create a project → enable "YouTube Data API v3"
# 2. Create OAuth 2.0 credentials (Desktop app type) → download client_secret.json
# 3. Run: python scripts/youtube_auth_setup.py   (one-time, generates refresh token)
# 4. Copy the printed values here / into GitHub secrets.
YT_CLIENT_ID=
YT_CLIENT_SECRET=
YT_REFRESH_TOKEN=
YT_CHANNEL_HANDLE=@your_yt_handle   # optional, used in video description
